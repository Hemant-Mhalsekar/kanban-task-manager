# ── Dependencies ──────────────────────────────────────────────
node_modules/

# ── Environment variables ──────────────────────────────────────
.env
.env.*
!.env.example

# ── Postman ────────────────────────────────────────────────────
# Collections are safe to commit (API definitions only).
# Environments contain live tokens/secrets — never commit them.
postman/environments/
postman/globals/

# ── Build outputs ──────────────────────────────────────────────
dist/
dist-ssr/
build/

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS files ──────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor ────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Misc ──────────────────────────────────────────────────────
*.local
.cache/
